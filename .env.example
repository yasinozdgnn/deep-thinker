# === Deep Thinker Configuration ===
# AI Provider: zen | go | openrouter | gemini
AI_PROVIDER=zen

# --- ZEN API (Free Models) ---
# https://opencode.ai/zen/v1
ZEN_API_KEY=your_z...n
ZEN_MODEL=deepseek-v4-flash-free
ZEN_API_TIMEOUT=300000

# --- GO API (Paid Models via OpenCode Go) ---
# https://opencode.ai/zen/go/v1
GO_API_KEY=your_go_api_key
GO_M...n
# --- OpenRouter ---
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=openrouter/free

# --- Google Gemini (Direct SDK) ---
GEMINI_API_KEY=your_gemini_key

# --- OpenCode CLI ---
OPENCODE_PATH=opencode

# --- Proxy ---
PROXY_PORT=3456
